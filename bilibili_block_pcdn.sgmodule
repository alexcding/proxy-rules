#!name=Bilibili Prefer COSOV
#!desc=Rewrite Bilibili upgcxcode media requests on Tencent COS mirrors to upos-sz-mirrorcosov.bilivideo.com (COS overseas mirror, low-latency from outside China). Only COS-family hosts are rewritten so the upsig signature stays within the same backend. Requires MITM trust on the watching device.

[URL Rewrite]
^https?:\/\/upos-(?:sz|hz|bstar)-mirrorcos[a-z0-9]*\.bilivideo\.com\/(upgcxcode\/.*) https://upos-sz-mirrorcosov.bilivideo.com/$1 header

[MITM]
hostname = %APPEND% *.bilivideo.com
